{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "LoadTest": {
    "ConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=InboxNetLoadTest;Integrated Security=true;TrustServerCertificate=true;Max Pool Size=200;",
    "TotalMessages": 5000,
    "PublisherConcurrency": 50,
    "BatchSize": 100,
    "MaxConcurrentDispatch": 200,
    "ColdPollingIntervalMs": 1000,
    "ReceiverPort": 5556,
    "WebhookSecret": "loadtest-secret",
    "HandlerFailureRate": 0.00,
    "DrainTimeout": "00:02:00",
    "TruncateBeforeRun": true,
    "BulkBookkeeping": false,
    "RecordAttemptsOnSuccess": true,
    "RecordHandlerAttempts": true
  }
}
